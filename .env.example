# Copy to .env and fill in. Get these from the Backblaze B2 console under
# App Keys. Names match what tests/test_b2_connection.py and b2sdk expect.
keyID=
applicationKey=

# Used by nova/agent/scene_breakdown.py (genblaze_openai.chat).
OPENAI_API_KEY=

# Primary image provider: Gemini 2.5 Flash Image / "nano-banana" (backlog 3.2),
# via nova/providers/gemini_image.py. Same var genblaze-google reads, so one
# key also covers the Veo video stage later. Get it from https://aistudio.google.com/apikey
# Without this, tests marked `live` skip and the image stage cannot generate.
GEMINI_API_KEY=

# Project/shot state (nova/models/project.py). Defaults to a local SQLite
# file if unset; point at managed Postgres in production.
DATABASE_URL=

# --- Animatic (video) stage — nova/pipeline/animatic_stage.py ---------------
# Primary: Runway gen4_turbo. Fallback: Luma ray-2. Each genblaze provider
# SDK reads its own conventional var. Optional third fallback: GMI Cloud
# draft video, enabled only when GMI_VIDEO_MODEL is set.
RUNWAYML_API_SECRET=
LUMAAI_API_KEY=
GMI_API_KEY=
GMI_VIDEO_MODEL=
# Draft-tier Flux image fallback via GMI Cloud (backlog 3.3), enabled only
# when GMI_FLUX_MODEL is set (needs GMI_API_KEY too).
GMI_FLUX_MODEL=

# --- Audio stage — nova/pipeline/audio_stage.py -----------------------------
# Primary: Stability Audio (nova/providers/stability_audio.py). Fallback:
# ElevenLabs SFX (genblaze_elevenlabs).
STABILITY_API_KEY=
ELEVENLABS_API_KEY=

# --- Lock -> animatic trigger (see README "three modes") --------------------
# direct (default) | webhook. The poller (scripts/run_poller.py) runs
# alongside either mode.
NOVA_EVENT_MODE=
# Required only for webhook mode + scripts/setup_event_notification.py:
NOVA_WEBHOOK_URL=
B2_WEBHOOK_SIGNING_SECRET=

# --- Assembly ---------------------------------------------------------------
# Optional: explicit ffmpeg binary. If unset, PATH ffmpeg is used, falling
# back to the bundled imageio-ffmpeg binary.
FFMPEG_PATH=
